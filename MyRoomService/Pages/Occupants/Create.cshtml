@page
@model MyRoomService.Pages.Occupants.CreateModel
@{
    ViewData["Title"] = "Register Occupant";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">

            @* Navigation Back *@
            <a asp-page="./Index" class="text-decoration-none small mb-3 d-inline-block text-muted">
                <i class="bi bi-arrow-left"></i> Back to Occupant Directory
            </a>

            <div class="card border-0 shadow-lg rounded-4 mb-4">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                            <i class="bi bi-person-plus fs-2"></i>
                        </div>
                        <h3 class="fw-bold">Register Occupant</h3>
                        <p class="text-muted small">Create a new profile before assigning to a unit.</p>
                    </div>

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="row g-3">
                            @* First Name *@
                            <div class="col-md-6">
                                <label asp-for="Occupant.FirstName" class="form-label fw-semibold small">First Name</label>
                                <input asp-for="Occupant.FirstName" class="form-control rounded-3" placeholder="John" />
                                <span asp-validation-for="Occupant.FirstName" class="text-danger small"></span>
                            </div>

                            @* Last Name *@
                            <div class="col-md-6">
                                <label asp-for="Occupant.LastName" class="form-label fw-semibold small">Last Name</label>
                                <input asp-for="Occupant.LastName" class="form-control rounded-3" placeholder="Doe" />
                                <span asp-validation-for="Occupant.LastName" class="text-danger small"></span>
                            </div>

                            @* Email *@
                            <div class="col-12">
                                <label asp-for="Occupant.Email" class="form-label fw-semibold small">Email Address</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope"></i></span>
                                    <input asp-for="Occupant.Email" class="form-control border-start-0 rounded-end-3" placeholder="name@example.com" />
                                </div>
                                <span asp-validation-for="Occupant.Email" class="text-danger small"></span>
                            </div>

                            @* Phone *@
                            <div class="col-12">
                                <label asp-for="Occupant.Phone" class="form-label fw-semibold small">Phone Number</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-telephone"></i></span>
                                    <input asp-for="Occupant.Phone" class="form-control border-start-0 rounded-end-3" placeholder="0912 345 6789" />
                                </div>
                                <span asp-validation-for="Occupant.Phone" class="text-danger small"></span>
                            </div>

                            @* KYC Status (Hidden) *@
                            <input type="hidden" asp-for="Occupant.KycStatus" />
                        </div>

                        <hr class="my-5 text-muted" />

                        @* 🚨 Initial Billing Section *@
                        <div class="mb-4">
                            <h5 class="fw-bold text-primary mb-3"><i class="bi bi-wallet2 me-2"></i>Initial Billing</h5>
                            <p class="text-muted small mb-4">Set up Move-In Requirements (Advance & Deposit).</p>

                            <div class="form-check form-switch mb-4">
                                <input class="form-check-input" type="checkbox" id="generateInvoiceToggle" asp-for="GenerateInitialInvoice" checked>
                                <label class="form-check-label fw-bold ms-2" for="generateInvoiceToggle">
                                    Generate Deposit/Advance Invoice Now
                                </label>
                                <div class="form-text ms-2">Creates a pending invoice so the occupant can pay and become Verified.</div>
                            </div>

                            <div class="row g-3" id="initialChargesDiv">
                                <div class="col-md-6">
                                    <label asp-for="AdvanceAmount" class="form-label fw-bold small">Advance Rent</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light">₱</span>
                                        <input asp-for="AdvanceAmount" class="form-control" placeholder="0.00" type="number" step="0.01" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="DepositAmount" class="form-label fw-bold small">Security Deposit</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light">₱</span>
                                        <input asp-for="DepositAmount" class="form-control" placeholder="0.00" type="number" step="0.01" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        @* Submit Buttons *@
                        <div class="row mt-4 pt-3 border-top">
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold shadow-sm">
                                    Create Profile & Invoice
                                </button>
                                <a asp-page="./Index" class="btn btn-link w-100 text-muted mt-2 small text-decoration-none text-center d-block">Cancel</a>
                            </div>
                        </div>

                    </form>
                </div>
            </div>

            @* Security Note *@
            <div class="text-center mt-4">
                <p class="text-muted" style="font-size: 0.75rem;">
                    <i class="bi bi-shield-lock"></i> All data is isolated to your organization.
                </p>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('generateInvoiceToggle').addEventListener('change', function() {
            var chargesDiv = document.getElementById('initialChargesDiv');
            chargesDiv.style.opacity = this.checked ? '1' : '0.4';
            chargesDiv.style.pointerEvents = this.checked ? 'auto' : 'none';
        });
    </script>
}